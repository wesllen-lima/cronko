{
  "name": "@cronko/api",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node24 --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cronko/database": "workspace:*",
    "@cronko/shared": "workspace:*",
    "@hono/node-server": "^2",
    "@hono/zod-validator": "^0.8",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12",
    "drizzle-orm": "^0.45",
    "hono": "^4",
    "nodemailer": "^8",
    "postgres": "^3",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/node": "^25",
    "@types/nodemailer": "^8",
    "tsup": "^8.5.1",
    "tsx": "^4",
    "typescript": "^6"
  }
}