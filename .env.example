# Banco de dados
# SQLite (padrão para desenvolvimento):
DATABASE_URL=file:./data/cronko.db
# PostgreSQL (produção):
# DATABASE_URL=postgresql://cronko:cronko@localhost:5432/cronko

# API
API_PORT=3001
API_HOST=0.0.0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Autenticação — JWT
# Gerado com: openssl rand -base64 64
JWT_SECRET=change-this-in-production-min-32-chars

# Admin seed (primeiro startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Notificações — Email (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=cronko@example.com

# Notificações — Telegram (opcional)
TELEGRAM_BOT_TOKEN=