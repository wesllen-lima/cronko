# Cronko environment variables
# Copy to .env and fill in the required values.

# Database (required)
DATABASE_URL=file:./data/cronko.db

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS — additional origins, comma-separated (e.g. https://a.example.com,https://b.example.com)
# CORS_ORIGINS=

# Security (required in production — generate with: openssl rand -base64 32)
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TELEGRAM_BOT_TOKEN=

# Logging (development | production | test)
# LOG_LEVEL=info

# Redis (optional — enables distributed rate limiting)
# REDIS_URL=redis://localhost:6379

# PostgreSQL (Docker Compose)
# POSTGRES_USER=cronko
# POSTGRES_PASSWORD=
# POSTGRES_DB=cronko