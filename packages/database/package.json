{
  "name": "@cronko/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./queries/monitors": "./src/queries/monitors.ts",
    "./queries/heartbeats": "./src/queries/heartbeats.ts",
    "./queries/incidents": "./src/queries/incidents.ts",
    "./queries/notifications": "./src/queries/notifications.ts",
    "./queries/settings": "./src/queries/settings.ts",
    "./queries/users": "./src/queries/users.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45",
    "better-sqlite3": "^12",
    "postgres": "^3",
    "@cronko/shared": "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31",
    "@types/better-sqlite3": "^7",
    "@types/node": "^25",
    "typescript": "^6"
  }
}